## 3. Terraform scaffold (with Postgres)

### 3.1 VPC module (as before, unchanged)

`terraform/modules/vpc/*` — same as previous answer (CIDR, public/private subnets, outputs).

---

### 3.2 EKS module (simplified)

`terraform/modules/eks/*` — same as previous answer (using `terraform-aws-modules/eks/aws`).

---

### 3.3 Prometheus module (AMP)

`terraform/modules/prometheus/*` — same as previous answer.

---

### 3.4 RabbitMQ module (Amazon MQ)

`terraform/modules/rabbitmq/*` — same as previous answer.

---

### 3.5 Postgres module (RDS)

**Dir:** `terraform/modules/postgres/`

**File:** `terraform/modules/postgres/main.tf`

```hcl
terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

resource "aws_db_subnet_group" "this" {
  name       = "${var.name}-subnet-group"
  subnet_ids = var.subnet_ids

  tags = var.tags
}

resource "aws_db_instance" "this" {
  identifier        = var.name
  engine            = "postgres"
  engine_version    = var.engine_version
  instance_class    = var.instance_class
  allocated_storage = var.allocated_storage

  db_name  = var.db_name
  username = var.username
  password = var.password

  db_subnet_group_name   = aws_db_subnet_group.this.name
  vpc_security_group_ids = var.security_group_ids

  multi_az               = var.multi_az
  storage_encrypted      = true
  backup_retention_period = var.backup_retention_days

  skip_final_snapshot = var.skip_final_snapshot

  tags = var.tags
}

output "endpoint" {
  value = aws_db_instance.this.address
}

output "port" {
  value = aws_db_instance.this.port
}
```

**File:** `terraform/modules/postgres/variables.tf`

```hcl
variable "name" {
  type        = string
  description = "Identifier/name for the Postgres instance."
}

variable "engine_version" {
  type        = string
  default     = "16.2"
}

variable "instance_class" {
  type        = string
  default     = "db.m6g.large"
}

variable "allocated_storage" {
  type        = number
  default     = 100
}

variable "db_name" {
  type        = string
  description = "Database name."
}

variable "username" {
  type        = string
  sensitive   = true
}

variable "password" {
  type        = string
  sensitive   = true
}

variable "subnet_ids" {
  type        = list(string)
  description = "Private subnet IDs for RDS."
}

variable "security_group_ids" {
  type        = list(string)
  description = "Security groups for RDS."
}

variable "multi_az" {
  type        = bool
  default     = true
}

variable "backup_retention_days" {
  type        = number
  default     = 7
}

variable "skip_final_snapshot" {
  type        = bool
  default     = false
}

variable "tags" {
  type        = map(string)
  default     = {}
}
```

---

### 3.6 Sandbox environment (using Postgres too)

**Dir:** `terraform/envs/sandbox/`

**File:** `terraform/envs/sandbox/backend.tf`

```hcl
terraform {
  backend "s3" {
    bucket         = "org-tfstate-sandbox"
    key            = "migration/terraform.tfstate"
    region         = "eu-west-1"
    dynamodb_table = "org-tf-locks-sandbox"
    encrypt        = true
  }
}
```

**File:** `terraform/envs/sandbox/providers.tf`

```hcl
terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "eu-west-1"
}
```

**File:** `terraform/envs/sandbox/main.tf`

```hcl
module "vpc" {
  source          = "../../modules/vpc"
  name            = "sandbox"
  cidr_block      = "10.10.0.0/16"
  public_subnets  = ["10.10.1.0/24", "10.10.2.0/24"]
  private_subnets = ["10.10.11.0/24", "10.10.12.0/24"]
  tags = {
    Environment = "sandbox"
    Project     = "onprem-migration"
  }
}

module "eks" {
  source             = "../../modules/eks"
  cluster_name       = "sandbox-eks"
  vpc_id             = module.vpc.vpc_id
  private_subnet_ids = module.vpc.private_subnet_ids
  tags = {
    Environment = "sandbox"
    Project     = "onprem-migration"
  }
}

module "prometheus" {
  source = "../../modules/prometheus"
  alias  = "sandbox-prometheus"
  tags = {
    Environment = "sandbox"
    Project     = "onprem-migration"
  }
}

# Example: security group for Postgres (simplified)
resource "aws_security_group" "postgres" {
  name        = "sandbox-postgres-sg"
  description = "Postgres access"
  vpc_id      = module.vpc.vpc_id

  # In real org: restrict to app subnets / EKS nodes
  ingress {
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = ["10.10.0.0/16"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Environment = "sandbox"
    Project     = "onprem-migration"
  }
}

module "postgres" {
  source             = "../../modules/postgres"
  name               = "sandbox-postgres"
  db_name            = "appdb"
  username           = "appuser"
  password           = "CHANGE_ME"
  subnet_ids         = module.vpc.private_subnet_ids
  security_group_ids = [aws_security_group.postgres.id]
  tags = {
    Environment = "sandbox"
    Project     = "onprem-migration"
  }
}
```

Staging/prod envs mirror this with different backends, CIDRs, sizes, and stricter SGs.

